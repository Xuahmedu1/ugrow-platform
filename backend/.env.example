# UGROW Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================

# Application environment (development, production, testing)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=true

# Application port
PORT=8000

# Application host
HOST=0.0.0.0

# ============================================
# Database Configuration (PostgreSQL)
# ============================================

# Database URL (preferred method)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://ugrow:ugrow_password@localhost:5432/ugrow_db

# Or use individual components:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ugrow_db
# DB_USER=ugrow
# DB_PASSWORD=ugrow_password

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# Authentication & Security
# ============================================

# JWT Secret Key (generate a strong random string)
# Use: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# JWT Access Token expiration (minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# JWT Refresh Token expiration (days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Algorithm for JWT
JWT_ALGORITHM=HS256

# Password hashing rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# AES-256 encryption key for platform credentials (32 bytes, base64 encoded)
# Use: openssl rand -base64 32
PLATFORM_CREDENTIALS_ENCRYPTION_KEY=your-encryption-key-here-base64-32-bytes=

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (comma-separated for multiple)
# In production, specify exact domains: https://app.ugrow.com,https://admin.ugrow.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# ============================================
# File Storage
# ============================================

# Storage type: local, s3, azure, gcs
STORAGE_TYPE=local

# Local storage path (for STORAGE_TYPE=local)
LOCAL_STORAGE_PATH=./storage

# Maximum upload file size (MB)
MAX_UPLOAD_SIZE=10

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.xlsx,.xls,.csv

# ============================================
# AWS S3 Configuration (if STORAGE_TYPE=s3)
# ============================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=ugrow-uploads

# ============================================
# Email Configuration (SMTP)
# ============================================

# SMTP server host
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_TLS=true

# From address for system emails
# SMTP_FROM_EMAIL=noreply@ugrow.com
# SMTP_FROM_NAME=UGROW Platform

# ============================================
# Logging
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text

# ============================================
# Master Sheet Template
# ============================================

# Path to Master_Sheet.xlsx template file
MASTER_SHEET_TEMPLATE_PATH=./templates/Master_Sheet.xlsx

# Default output directory for exports
EXPORTS_OUTPUT_PATH=./exports

# ============================================
# Redis (Optional - for caching and session storage)
# ============================================

# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=
# REDIS_SSL=false

# ============================================
# Rate Limiting
# ============================================

# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Burst allowance
RATE_LIMIT_BURST=10

# ============================================
# Admin Credentials (Seeded on first run)
# ============================================

# Default admin email (cannot be changed via UI)
ADMIN_EMAIL=admin@ugrow.com

# Default admin password (change immediately after first login)
ADMIN_PASSWORD=ugrow1@@

# ============================================
# External APIs (Optional Integrations)
# ============================================

# Talabat API credentials (if using direct API instead of file uploads)
# TALABAT_API_KEY=
# TALABAT_API_SECRET=

# Noon API credentials
# NOON_API_KEY=
# NOON_API_SECRET=

# ============================================
# Testing
# ============================================

# Test database URL (isolated from main DB)
# TEST_DATABASE_URL=postgresql://ugrow_test:test@localhost:5432/ugrow_test_db

# ============================================
# Production Security Headers
# ============================================

# Enable security headers (HSTS, CSP, etc.)
# SECURITY_HEADERS_ENABLED=true

# Content Security Policy (careful with this)
# CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline';