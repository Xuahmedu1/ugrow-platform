# UGROW Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# API Configuration
# ============================================

# Backend API URL (required)
# Use http://localhost:8000 for local development
# Use your production API URL for production builds
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time updates (optional)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ============================================
# Authentication
# ============================================

# JWT token expiration warning threshold (minutes)
NEXT_PUBLIC_TOKEN_EXPIRY_WARNING=5

# ============================================
# Feature Flags
# ============================================

# Enable/disable analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Enable/disable debug mode
NEXT_PUBLIC_DEBUG_MODE=false

# ============================================
# File Upload Configuration
# ============================================

# Maximum file upload size in MB
NEXT_PUBLIC_MAX_FILE_SIZE=10

# Allowed file types for upload (comma-separated)
NEXT_PUBLIC_ALLOWED_FILE_TYPES=.xlsx,.xls,.csv

# ============================================
# Internationalization
# ============================================

# Default locale
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Supported locales (comma-separated)
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar

# ============================================
# Branding
# ============================================

# Company name for meta tags
NEXT_PUBLIC_COMPANY_NAME=UGROW

# Support email
NEXT_PUBLIC_SUPPORT_EMAIL=support@ugrow.com

# ============================================
# Build Configuration
# ============================================

# Image optimization domain (if using external CDN)
# NEXT_PUBLIC_IMAGE_DOMAIN=cdn.ugrow.com

# Static export for deployment without Node.js server
# NEXT_PUBLIC_STATIC_EXPORT=false